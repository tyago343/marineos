{
  "expo": {
    "name": "MarineOS",
    "slug": "marineos",
    "scheme": "marineos",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marineos.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0066CC"
      },
      "package": "com.marineos.app"
    },
    "plugins": ["expo-router", "expo-localization"]
  }
}
